// ====================================================================
// Utilitários de entrada
// ====================================================================
static double readDouble(const std::string& prompt, double min, double max) {
    double v;
    while (true) {
        std::cout << prompt << " [" << min << "-" << max << "]: ";
        if (std::cin >> v && v >= min && v <= max) return v;
        std::cout << "  Valor inválido. Tente novamente.\n";
        std::cin.clear();
        std::cin.ignore(std::numeric_limits<std::streamsize>::max(), '\n');
    }
}

static int readInt(const std::string& prompt, int min, int max) {
    int v;
    while (true) {
        std::cout << prompt << " [" << min << "-" << max << "]: ";
        if (std::cin >> v && v >= min && v <= max) return v;
        std::cout << "  Valor inválido. Tente novamente.\n";
        std::cin.clear();
        std::cin.ignore(std::numeric_limits<std::streamsize>::max(), '\n');
    }
}

// ====================================================================
// Interface de texto / Menu do MVP
// ====================================================================
void printHeader() {
    std::cout << "\n";
    std::cout << "╔══════════════════════════════════════════════════════════╗\n";
    std::cout << "║          GPS - GEOPOLITICAL SIMULATOR  v0.1.0          ║\n";
    std::cout << "║        Simulação Geopolítica Total em Tempo Real       ║\n";
    std::cout << "╚══════════════════════════════════════════════════════════╝\n";
    std::cout << "\n";
}

void printCountryDashboard(const WorldState& world, CountryID id) {
    const auto& c = world.getCountry(id);

    std::cout << "\n╔══════════════════════════════════════════════════════════╗\n";
    std::cout << "║   " << std::left << std::setw(50) << c.name << "     ║\n";
    std::cout << "╠══════════════════════════════════════════════════════════╣\n";

    std::cout << std::fixed << std::setprecision(1);
    std::cout << "║ População: " << std::setw(8) << c.population << "M"
              << "  | PIB: $" << std::setw(10) << c.gdp.billions << "B"
              << "     ║\n";
    std::cout << "║ Cresc.PIB: " << std::setw(6) << (c.gdpGrowthRate * 100.0) << "%"
              << "  | Inflação: " << std::setw(7) << (c.inflation * 100.0) << "%"
              << "     ║\n";
    std::cout << "║ Desemprego:" << std::setw(6) << (c.unemploymentRate * 100.0) << "%"
              << "  | Dívida/PIB: " << std::setw(5) << (c.debtToGDP * 100.0) << "%"
              << "    ║\n";
    std::cout << "║ Aprovação: " << std::setw(6) << (c.governmentApproval * 100.0) << "%"
              << "  | Estabili.: " << std::setw(5) << (c.internalStability * 100.0) << "%"
              << "    ║\n";
    std::cout << "║ IDH: " << std::setprecision(3) << std::setw(5) << c.hdi
              << std::setprecision(1)
              << "        | Democracia: " << std::setw(5) << (c.democracy * 100.0) << "%"
              << "    ║\n";
    std::cout << "║ Corrupção: " << std::setw(6) << (c.corruption * 100.0) << "%"
              << "  | Poder Soft: " << std::setw(4) << (c.softPower * 100.0) << "%"
              << "     ║\n";
    std::cout << "║ Militar: " << std::setw(8) << c.military.activePersonnel << " efetivos"
              << "                      ║\n";

    if (c.military.nuclearWarheads > 0) {
        std::cout << "║ ☢ Ogivas Nucleares: " << std::setw(5) << c.military.nuclearWarheads
                  << "                              ║\n";
    }
    std::cout << "╚══════════════════════════════════════════════════════════╝\n";
}

void printMenu(const SimDate& date) {
    std::cout << std::right;
    std::cout << "\n  Data: " << date.year << "/" << std::setw(2) << std::setfill('0')
              << (int)date.month << "/" << std::setw(2) << (int)date.day << std::setfill(' ') << "\n";
    std::cout << "═══════════════════ AÇÕES ═══════════════════\n";
    std::cout << "  [1]  Painel do País\n";
    std::cout << "  [2]  Economia  (impostos, orçamento, câmbio)\n";
    std::cout << "  [3]  Diplomacia (relações, propostas, guerras)\n";
    std::cout << "  [4]  Militar   (forças, operações, conflitos)\n";
    std::cout << "  [5]  Legislação (propor leis, revogar, vigentes)\n";
    std::cout << "  [6]  Inteligência (agências, operações ocultas)\n";
    std::cout << "  [7]  Ranking Mundial\n";
    std::cout << "  [8]  Avançar 1 dia\n";
    std::cout << "  [9]  Avançar 1 mês\n";
    std::cout << "  [10] Avançar 1 ano\n";
    std::cout << "  [0]  Sair\n";
    std::cout << "═════════════════════════════════════════════\n";
    std::cout << "Escolha: ";
}

void printWorldRanking(const WorldState& world) {
    struct RankEntry {
        CountryID id;
        std::string name;
        double gdp;
        double population;
        double power;
    };

    std::vector<RankEntry> entries;
    for (auto cid : world.getAllCountryIds()) {
        const auto& c = world.getCountry(cid);
        entries.push_back({cid, c.name, c.gdp.billions, c.population, c.calculatePowerIndex()});
    }

    std::sort(entries.begin(), entries.end(), [](const RankEntry& a, const RankEntry& b) {
        return a.power > b.power;
    });

    std::cout << "\n╔══════════════════════════════════════════════════════════════════╗\n";
    std::cout << "║                     RANKING MUNDIAL                             ║\n";
    std::cout << "╠════╦══════════════════╦════════════╦════════════╦════════════════╣\n";
    std::cout << "║ #  ║ País             ║ PIB ($B)   ║ Pop. (M)   ║ Índice Poder   ║\n";
    std::cout << "╠════╬══════════════════╬════════════╬════════════╬════════════════╣\n";

    int rank = 1;
    for (const auto& e : entries) {
        std::cout << "║ " << std::setw(2) << rank++ << " ║ "
                  << std::left << std::setw(16) << e.name << " ║ "
                  << std::right << std::setw(10) << std::fixed << std::setprecision(1) << e.gdp << " ║ "
                  << std::setw(10) << e.population << " ║ "
                  << std::setw(14) << std::setprecision(3) << e.power << " ║\n";
    }
    std::cout << "╚════╩══════════════════╩════════════╩════════════╩════════════════╝\n";
}

void printDiplomacy(const WorldState& world, CountryID playerId) {
    std::cout << "\n╔════════════════════════════════════════════════════════════════╗\n";
    std::cout << "║              RELAÇÕES DIPLOMÁTICAS                            ║\n";
    std::cout << "╠══╦══════════════════╦════════╦══════════╦════════════════════╣\n";
    std::cout << "║ID║ País             ║Relações║ Status   ║ Acordos            ║\n";
    std::cout << "╠══╬══════════════════╬════════╬══════════╬════════════════════╣\n";

    for (auto cid : world.getAllCountryIds()) {
        if (cid == playerId) continue;
        const auto& other = world.getCountry(cid);
        const auto& rel = world.getRelation(playerId, cid);

        std::string statusStr;
        switch (rel.status) {
            case DiplomaticStatus::ALLIED:    statusStr = "ALIADO  "; break;
            case DiplomaticStatus::FRIENDLY:  statusStr = "AMIGÁVEL"; break;
            case DiplomaticStatus::NEUTRAL:   statusStr = "NEUTRO  "; break;
            case DiplomaticStatus::COOL:      statusStr = "FRIO    "; break;
            case DiplomaticStatus::HOSTILE:   statusStr = "HOSTIL  "; break;
            case DiplomaticStatus::AT_WAR:    statusStr = "GUERRA! "; break;
            case DiplomaticStatus::EMBARGO:   statusStr = "EMBARGO "; break;
            case DiplomaticStatus::SANCTIONS: statusStr = "SANÇÕES "; break;
            default: statusStr = "???     "; break;
        }

        std::string acordos;
        if (rel.hasTradeAgreement)   acordos += "[Comercio]";
        if (rel.hasMilitaryAlliance) acordos += "[Aliança] ";
        if (rel.hasSanctions)        acordos += "[Sancoes] ";
        if (acordos.empty()) acordos = "-";

        std::cout << std::right << "║" << std::setw(2) << cid << "║ "
                  << std::left << std::setw(16) << other.name << " ║"
                  << std::right << std::fixed << std::setprecision(0)
                  << std::setw(7) << rel.relations << " ║ "
                  << statusStr << " ║ "
                  << std::left << std::setw(18) << acordos << " ║\n";
    }
    std::cout << "╚══╩══════════════════╩════════╩══════════╩════════════════════╝\n";
}

